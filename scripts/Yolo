import os
os.chdir("D:/datasets")  # 切换到数据集目录

from ultralytics import YOLO

# 加载预训练模型
model = YOLO("yolov8n.pt")
# 重新加载官方模型，确保是同一版本
model_official = YOLO("yolov8n.pt")
model_yours = YOLO("runs/detect/runs/hand/rps/weights/best.pt")

# 详细对比
print(f"官方参数量: {sum(p.numel() for p in model_official.model.parameters())}")
print(f"你的参数量: {sum(p.numel() for p in model_yours.model.parameters())}")
# 开始训练
results = model.train(
    data="data.yaml",  # 配置文件路径
    epochs=100,          # 训练轮数（石头剪刀布50-100轮够了）
    imgsz=640,           # 输入图片尺寸
    batch=16,            # 批次大小（显存不够就降到8）
    device='0',        # 有GPU改'0'，没有就用'cpu'
    workers=0,           # Windows下建议设0
    patience=20,         # 20轮没提升就早停
    save=True,           # 保存最好的模型
    project="runs/hand", # 结果保存目录
    name="rps"           # 实验名称
)

print("训练完成！最佳模型保存在 runs/hand/rps/weights/best.pt")